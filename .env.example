# GreenIoT-MA - Example environment configuration

# Kafka
KAFKA_BROKERS=localhost:9092

# Delta Lake / MinIO
DELTA_BRONZE=s3a://greeniot/bronze
DELTA_SILVER=s3a://greeniot/silver
DELTA_GOLD=s3a://greeniot/gold
STREAMING_CHECKPOINT_ROOT=
STREAMING_RESET_CHECKPOINTS=false
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=greeniot
MINIO_SECRET_KEY=greeniot2030
AWS_REGION=us-east-1
AWS_ALLOW_HTTP=true
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_ALLOW_UNSAFE_RENAME=true

# MLflow
MLFLOW_URI=http://localhost:5000
MLFLOW_EXPERIMENT_PREDICTION=greeniot_consumption_prediction
MLFLOW_EXPERIMENT_ANOMALY=greeniot_anomaly_detection

# Simulation
SIMULATION_INTERVAL_SEC=5.0
SIMULATION_DAYS=7

# Real dataset paths (optional)
UCI_DATASET=
ASHRAE_DIR=
ASHRAE_TRAIN_DATASET=
ASHRAE_BUILDING_META=
ASHRAE_WEATHER_TRAIN=

# Data mode
# real      -> use UCI + ASHRAE local files
# synthetic -> pure synthetic generation
DATA_MODE=synthetic

# Dashboard / tests
DEMO_MODE=false
RUN_MINIO_TESTS=false
